<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.image.ImageView?>

<BorderPane fx:id="root" xmlns:fx="http://javafx.com/fxml" fx:controller="com.yinyue.player.controller.SongInfoController">
    <top>
        <TabPane>
            <Tab text="详细信息">
                <VBox spacing="10" padding="15">
                    <HBox spacing="10">
                        <ImageView fx:id="albumArtView" fitWidth="120" fitHeight="120"/>
                        <VBox spacing="5">
                            <TextField fx:id="titleField" promptText="标题" editable="false"/>
                            <TextField fx:id="artistField" promptText="艺术家" editable="false"/>
                            <TextField fx:id="albumField" promptText="专辑" editable="false"/>
                        </VBox>
                    </HBox>
                    <Separator/>
                    <GridPane hgap="10" vgap="5">
                        <Label text="时长" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <Label fx:id="durationLabel" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                        <Label text="文件大小" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <Label fx:id="fileSizeLabel" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                        <Label text="格式" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <Label fx:id="formatLabel" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                        <Label text="比特率" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                        <Label fx:id="bitRateLabel" GridPane.columnIndex="1" GridPane.rowIndex="3"/>
                        <Label text="采样率" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                        <Label fx:id="sampleRateLabel" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                        <Label text="声道" GridPane.columnIndex="0" GridPane.rowIndex="5"/>
                        <Label fx:id="channelsLabel" GridPane.columnIndex="1" GridPane.rowIndex="5"/>
                    </GridPane>
                </VBox>
            </Tab>
            
            <Tab text="文件信息">
                <VBox spacing="10" padding="15">
                    <Label text="文件路径"/>
                    <Label fx:id="filePathLabel" wrapText="true"/>
                    <Button text="打开文件位置" onAction="#onOpenFileLocation"/>
                </VBox>
            </Tab>
            
            <Tab text="歌词">
                <VBox padding="15">
                    <TextArea fx:id="lyricsArea" editable="false" VBox.vgrow="ALWAYS"/>
                </VBox>
            </Tab>
        </TabPane>
    </top>
    
    <bottom>
        <HBox alignment="CENTER_RIGHT" spacing="10" padding="10">
            <Button text="关闭" onAction="#onClose"/>
        </HBox>
    </bottom>
</BorderPane>